.import <arithmetic>
.import <control_flow>
.import <function>
.import <io>
.import <list>
.import <memory>
.import <stack>

.fn product
  RET #12

.main
  ADD $0, #2, #3
  LOAD $0, $0
  JMP after_jump
after_jump:
  JMP_IF done, #false
  CALL product
  POP $1
  LOAD $10, #0
  LOAD $11, #0
  LOAD $12, #0
  LOAD $13, #0
  LIST_NEW $20, #0
  LIST_PUSH $20, #0
  LIST_PUSH $20, #0
  LIST_PUSH $20, #0
  LIST_PUSH $20, #0
  PRINTLN $0
  PRINTLN $1
done:
  HALT
  PRINTLN #~"unreachable"
