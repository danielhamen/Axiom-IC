y_loop:
  JMP_GTE done, $1, @1

  CAST_FLOAT $2, $1
  MUL $3, $2, @9
  DIV $4, $3, @1
  ADD $5, @6, $4

  LOAD $6, #0

x_loop:
  JMP_GTE next_y, $6, @0

  CAST_FLOAT $7, $6
  MUL $8, $7, @8
  DIV $9, $8, @0
  ADD $10, @4, $9

  LOAD $11, #0.0
  LOAD $12, #0.0
  LOAD $13, #0
  LOAD $14, #0.0
  LOAD $15, #0.0
  LOAD $16, #0.0
  LOAD $17, #0.0
  LOAD $18, #0.0
  LOAD $19, #false

escape_loop:
  JMP_GTE escaped_or_maxed, $13, @2

  MUL $14, $11, $11
  MUL $15, $12, $12
  ADD $16, $14, $15
  JMP_GT escaped_or_maxed, $16, @10

  MUL $17, $11, $12
  MUL $17, $17, #2.0
  ADD $17, $17, $5

  SUB $18, $14, $15
  ADD $18, $18, $10

  LOAD $11, $18
  LOAD $12, $17
  INC $13, $13

  JMP escape_loop

escaped_or_maxed:
  MOD $20, $13, @3
  LIST_GET $21, $0, $20
  INC $21, $21
  LIST_SET $0, $20, $21

  INC $22, $6
  MUL $23, $13, $22
  ADD $24, $3, $23

  INC $25, $1
  MUL $23, $20, $25
  ADD $24, $24, $23

  MUL $23, $13, @14
  ADD $24, $24, $23

  MUL $23, $20, @15
  ADD $24, $24, $23

  ADD $3, $3, $24

  INC $6, $6
  JMP x_loop

next_y:
  MUL $26, $1, @16
  ADD $27, $3, $26
  FMOD $28, $27, @3
  CAST_INT $28, $28
  LIST_GET $29, $0, $28
  ADD $29, $29, $1
  LIST_SET $0, $28, $29

  INC $1, $1
  JMP y_loop

done:
  LIST_GET $30, $0, #0
  LIST_GET $31, $0, #1
