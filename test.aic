  ADD $62, $62, $63
  MUL $63, $39, @21
  ADD $62, $62, $63
  MUL $63, $40, @22
  ADD $62, $62, $63
  ADD $62, $62, $3

  FMOD $64, $62, #2147483647
  CAST_INT $64, $64
  STORE $65, $64

  HALT
